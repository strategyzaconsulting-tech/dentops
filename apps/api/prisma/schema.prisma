generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Practice {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  logoUrl    String?  @map("logo_url")
  brandColor String?  @map("brand_color")
  type              String?
  requireSpecialty  Boolean  @default(false) @map("require_specialty")
  createdAt         DateTime @default(now()) @map("created_at")

  users         User[]
  locations     Location[]
  timePunches   TimePunch[]
  ptoRequests   PtoRequest[]
  blackoutDates      BlackoutDate[]
  shifts             Shift[]
  clockAdjustments   ClockAdjustment[]
  openShifts         OpenShift[]
  openShiftClaims    OpenShiftClaim[]
  announcements      Announcement[]

  @@map("practices")
}

model User {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  practiceId String @map("practice_id") @db.Uuid
  firstName  String @map("first_name")
  lastName   String @map("last_name")
  email      String @unique
  role       String
  status     String

  pushToken   String?      @map("push_token")
  shiftStart  String?      @map("shift_start")
  shiftEnd    String?      @map("shift_end")

  practice         Practice          @relation(fields: [practiceId], references: [id])
  timePunches      TimePunch[]
  ptoRequests      PtoRequest[]
  shifts           Shift[]
  clockAdjustments ClockAdjustment[]
  openShiftClaims  OpenShiftClaim[]

  @@map("users")
}

model Location {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  practiceId String  @map("practice_id") @db.Uuid
  name       String
  address    String?
  city       String?
  state      String?
  zip        String?

  practice    Practice     @relation(fields: [practiceId], references: [id])
  timePunches TimePunch[]
  shifts      Shift[]
  openShifts  OpenShift[]

  @@map("locations")
}

model TimePunch {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  practiceId String    @map("practice_id") @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  locationId String    @map("location_id") @db.Uuid
  punchIn    DateTime  @map("punch_in")
  punchOut   DateTime? @map("punch_out")
  specialty  String?
  breakStart DateTime? @map("break_start")
  breakEnd   DateTime? @map("break_end")

  practice  Practice  @relation(fields: [practiceId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
  location  Location  @relation(fields: [locationId], references: [id])

  @@map("time_punches")
}

model PtoRequest {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  practiceId String   @map("practice_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  startDate  DateTime @map("start_date") @db.Date
  endDate    DateTime @map("end_date") @db.Date
  type       String
  status     String
  notes      String?

  practice Practice @relation(fields: [practiceId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@map("pto_requests")
}

model Shift {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  practiceId String   @map("practice_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  locationId String   @map("location_id") @db.Uuid
  date       DateTime @db.Date
  startTime  String   @map("start_time")
  endTime    String   @map("end_time")
  specialty  String?
  notes      String?

  practice Practice @relation(fields: [practiceId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@map("shifts")
}

model OpenShift {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  practiceId String   @map("practice_id") @db.Uuid
  locationId String   @map("location_id") @db.Uuid
  date       DateTime @db.Date
  startTime  String   @map("start_time")
  endTime    String   @map("end_time")
  specialty  String?
  notes      String?
  status     String   @default("open")
  createdAt  DateTime @default(now()) @map("created_at")

  practice Practice         @relation(fields: [practiceId], references: [id])
  location Location         @relation(fields: [locationId], references: [id])
  claims   OpenShiftClaim[]

  @@map("open_shifts")
}

model OpenShiftClaim {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  openShiftId String   @map("open_shift_id") @db.Uuid
  practiceId  String   @map("practice_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  status      String   @default("pending")
  createdAt   DateTime @default(now()) @map("created_at")

  openShift OpenShift @relation(fields: [openShiftId], references: [id], onDelete: Cascade)
  practice  Practice  @relation(fields: [practiceId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@map("open_shift_claims")
}

model ClockAdjustment {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  practiceId String   @map("practice_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  punchId    String?  @map("punch_id") @db.Uuid
  date       DateTime @db.Date
  type       String
  notes      String
  status     String   @default("pending")
  createdAt  DateTime @default(now()) @map("created_at")

  practice Practice @relation(fields: [practiceId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@map("clock_adjustments")
}

model BlackoutDate {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  practiceId String   @map("practice_id") @db.Uuid
  date       DateTime @db.Date
  reason     String?

  practice Practice @relation(fields: [practiceId], references: [id])

  @@map("blackout_dates")
}

model Announcement {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  practiceId String   @map("practice_id") @db.Uuid
  title      String
  body       String
  createdAt  DateTime @default(now()) @map("created_at")

  practice Practice @relation(fields: [practiceId], references: [id])

  @@map("announcements")
}
