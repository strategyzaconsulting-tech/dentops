generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Practice {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  logoUrl    String?  @map("logo_url")
  brandColor String?  @map("brand_color")
  type              String?
  requireSpecialty  Boolean  @default(false) @map("require_specialty")
  createdAt         DateTime @default(now()) @map("created_at")

  users         User[]
  locations     Location[]
  timePunches   TimePunch[]
  ptoRequests   PtoRequest[]
  blackoutDates      BlackoutDate[]
  shifts             Shift[]
  clockAdjustments   ClockAdjustment[]
  openShifts         OpenShift[]
  openShiftClaims    OpenShiftClaim[]
  announcements      Announcement[]
  practiceBenefits   PracticeBenefit[]
  userBenefits       UserBenefit[]
  onboardingChecklists OnboardingChecklist[]
  equipmentItems     EquipmentItem[]
  officeManuals      OfficeManual[]
  manualSignatures   ManualSignature[]
  trainingSessions   TrainingSession[]

  @@map("practices")
}

model User {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  practiceId String @map("practice_id") @db.Uuid
  firstName  String @map("first_name")
  lastName   String @map("last_name")
  email      String @unique
  role       String
  status     String

  pushToken   String?      @map("push_token")
  shiftStart  String?      @map("shift_start")
  shiftEnd    String?      @map("shift_end")

  practice         Practice          @relation(fields: [practiceId], references: [id])
  timePunches      TimePunch[]
  ptoRequests      PtoRequest[]
  shifts           Shift[]
  clockAdjustments ClockAdjustment[]
  openShiftClaims  OpenShiftClaim[]
  userBenefits     UserBenefit[]
  onboardingChecklists OnboardingChecklist[]
  equipmentItems   EquipmentItem[]
  manualSignatures ManualSignature[]
  trainingSessions TrainingSession[]
  trainerSessions  TrainingSession[] @relation("Trainer")

  @@map("users")
}

model Location {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  practiceId String  @map("practice_id") @db.Uuid
  name       String
  address    String?
  city       String?
  state      String?
  zip        String?

  practice    Practice     @relation(fields: [practiceId], references: [id])
  timePunches TimePunch[]
  shifts      Shift[]
  openShifts  OpenShift[]

  @@map("locations")
}

model TimePunch {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  practiceId String    @map("practice_id") @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  locationId String    @map("location_id") @db.Uuid
  punchIn    DateTime  @map("punch_in")
  punchOut   DateTime? @map("punch_out")
  specialty  String?
  breakStart DateTime? @map("break_start")
  breakEnd   DateTime? @map("break_end")

  practice  Practice  @relation(fields: [practiceId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
  location  Location  @relation(fields: [locationId], references: [id])

  @@map("time_punches")
}

model PtoRequest {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  practiceId String   @map("practice_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  startDate  DateTime @map("start_date") @db.Date
  endDate    DateTime @map("end_date") @db.Date
  type       String
  status     String
  notes      String?

  practice Practice @relation(fields: [practiceId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@map("pto_requests")
}

model Shift {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  practiceId String   @map("practice_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  locationId String   @map("location_id") @db.Uuid
  date       DateTime @db.Date
  startTime  String   @map("start_time")
  endTime    String   @map("end_time")
  specialty  String?
  notes      String?

  practice Practice @relation(fields: [practiceId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@map("shifts")
}

model OpenShift {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  practiceId String   @map("practice_id") @db.Uuid
  locationId String   @map("location_id") @db.Uuid
  date       DateTime @db.Date
  startTime  String   @map("start_time")
  endTime    String   @map("end_time")
  specialty  String?
  notes      String?
  status     String   @default("open")
  createdAt  DateTime @default(now()) @map("created_at")

  practice Practice         @relation(fields: [practiceId], references: [id])
  location Location         @relation(fields: [locationId], references: [id])
  claims   OpenShiftClaim[]

  @@map("open_shifts")
}

model OpenShiftClaim {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  openShiftId String   @map("open_shift_id") @db.Uuid
  practiceId  String   @map("practice_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  status      String   @default("pending")
  createdAt   DateTime @default(now()) @map("created_at")

  openShift OpenShift @relation(fields: [openShiftId], references: [id], onDelete: Cascade)
  practice  Practice  @relation(fields: [practiceId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@map("open_shift_claims")
}

model ClockAdjustment {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  practiceId String   @map("practice_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  punchId    String?  @map("punch_id") @db.Uuid
  date       DateTime @db.Date
  type       String
  notes      String
  status     String   @default("pending")
  createdAt  DateTime @default(now()) @map("created_at")

  practice Practice @relation(fields: [practiceId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@map("clock_adjustments")
}

model BlackoutDate {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  practiceId String   @map("practice_id") @db.Uuid
  date       DateTime @db.Date
  reason     String?

  practice Practice @relation(fields: [practiceId], references: [id])

  @@map("blackout_dates")
}

model PracticeBenefit {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  practiceId String  @map("practice_id") @db.Uuid
  name       String
  isDefault  Boolean @default(false) @map("is_default")
  sortOrder  Int     @default(0) @map("sort_order")

  practice     Practice      @relation(fields: [practiceId], references: [id])
  userBenefits UserBenefit[]

  @@map("practice_benefits")
}

model UserBenefit {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  practiceId String  @map("practice_id") @db.Uuid
  userId     String  @map("user_id") @db.Uuid
  benefitId  String  @map("benefit_id") @db.Uuid
  enabled    Boolean @default(false)

  practice Practice        @relation(fields: [practiceId], references: [id])
  user     User            @relation(fields: [userId], references: [id])
  benefit  PracticeBenefit @relation(fields: [benefitId], references: [id], onDelete: Cascade)

  @@unique([userId, benefitId])
  @@map("user_benefits")
}

model Announcement {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  practiceId String   @map("practice_id") @db.Uuid
  title      String
  body       String
  createdAt  DateTime @default(now()) @map("created_at")

  practice Practice @relation(fields: [practiceId], references: [id])

  @@map("announcements")
}

model OnboardingChecklist {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  practiceId String   @map("practice_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid

  i9CompletedAt               DateTime? @map("i9_completed_at") @db.Timestamptz()
  w4CompletedAt               DateTime? @map("w4_completed_at") @db.Timestamptz()
  personalInfoCompletedAt     DateTime? @map("personal_info_completed_at") @db.Timestamptz()
  emergencyContactCompletedAt DateTime? @map("emergency_contact_completed_at") @db.Timestamptz()
  directDepositCompletedAt    DateTime? @map("direct_deposit_completed_at") @db.Timestamptz()

  i9Data               Json? @map("i9_data")
  w4Data               Json? @map("w4_data")
  personalInfoData     Json? @map("personal_info_data")
  emergencyContactData Json? @map("emergency_contact_data")
  directDepositData    Json? @map("direct_deposit_data")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  practice       Practice        @relation(fields: [practiceId], references: [id])
  user           User            @relation(fields: [userId], references: [id])
  equipmentItems EquipmentItem[]

  @@unique([practiceId, userId])
  @@map("onboarding_checklists")
}

model EquipmentItem {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  practiceId   String   @map("practice_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  onboardingId String   @map("onboarding_id") @db.Uuid
  name         String
  serialNumber String?  @map("serial_number")
  assignedAt   DateTime @default(now()) @map("assigned_at") @db.Timestamptz()
  returnedAt   DateTime? @map("returned_at") @db.Timestamptz()
  notes        String?

  practice   Practice            @relation(fields: [practiceId], references: [id])
  user       User                @relation(fields: [userId], references: [id])
  onboarding OnboardingChecklist @relation(fields: [onboardingId], references: [id], onDelete: Cascade)

  @@map("equipment_items")
}

model OfficeManual {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  practiceId String   @unique @map("practice_id") @db.Uuid
  title      String
  content    String
  version    String   @default("1.0")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  practice   Practice          @relation(fields: [practiceId], references: [id])
  signatures ManualSignature[]

  @@map("office_manuals")
}

model ManualSignature {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  manualId   String   @map("manual_id") @db.Uuid
  practiceId String   @map("practice_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  signedAt   DateTime @default(now()) @map("signed_at") @db.Timestamptz()

  manual   OfficeManual @relation(fields: [manualId], references: [id], onDelete: Cascade)
  practice Practice     @relation(fields: [practiceId], references: [id])
  user     User         @relation(fields: [userId], references: [id])

  @@unique([manualId, userId])
  @@map("manual_signatures")
}

model TrainingSession {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  practiceId  String    @map("practice_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  trainerId   String?   @map("trainer_id") @db.Uuid
  topic       String
  scheduledAt DateTime  @map("scheduled_at") @db.Timestamptz()
  completedAt DateTime? @map("completed_at") @db.Timestamptz()
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  practice Practice @relation(fields: [practiceId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
  trainer  User?    @relation("Trainer", fields: [trainerId], references: [id])

  @@map("training_sessions")
}
